<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ displayName }} — {{ linkedDs }}</title>
  <link rel="stylesheet" href="../../tailwind.min.css">
  <link rel="stylesheet" href="../../styles.css">
  <!-- AGENT: emit Google Fonts <link> here based on the linked DS's typography.fontFamilies -->
  {{ GOOGLE_FONTS_LINKS }}
  <style>
    /*
     * AGENT: emit one --ds-* CSS variable per token this prototype actually uses.
     * EXAMPLE:
     *   :root {
     *     --ds-brand-primary: #2D5F3F;
     *     --ds-text-primary: #1A1A1A;
     *     --ds-text-inverse: #FFFFFF;
     *     --ds-button-height-lg: 52px;
     *     --ds-spacing-3: 12px;
     *     --ds-spacing-6: 24px;
     *     --ds-radius-lg: 12px;
     *   }
     */
    :root {
      {{ DS_CSS_VARIABLES }}
    }
  </style>
</head>
<body class="bg-gray-50 min-h-screen">

  <!-- Top nav -->
  <nav class="bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-8 py-4 flex items-center justify-between">
      <a href="../../index.html" class="text-sm text-gray-500 hover:text-gray-700">← Back to studio</a>
      <span class="text-xs font-mono text-gray-400">v{{ version }} · {{ lastModified }}</span>
    </div>
  </nav>

  <main class="max-w-6xl mx-auto px-8 py-12 space-y-12">

    <!-- Header -->
    <header>
      <h1 class="text-4xl font-semibold text-gray-900">{{ displayName }}</h1>
      <p class="text-lg text-gray-600 mt-2">{{ description }}</p>
      <div class="flex flex-wrap items-center gap-3 mt-4">
        <span class="px-3 py-1 rounded-full bg-gray-100 text-sm text-gray-700 font-mono">{{ archetype }}</span>
        <a href="../../design-systems/{{ linkedDs }}/detail.html" class="px-3 py-1 rounded-full bg-blue-50 text-sm text-blue-700 hover:bg-blue-100">
          DS: {{ linkedDs }} →
        </a>
        <!-- AGENT: emit one chip per breakpoint
          EXAMPLE: <span class="px-3 py-1 rounded-full bg-gray-100 text-sm text-gray-700">{{ BREAKPOINT_NAME }}</span>
        -->
        {{ BREAKPOINT_CHIPS }}
        <!-- AGENT: emit one chip per action
          EXAMPLE: <span class="px-3 py-1 rounded-full bg-purple-50 text-sm text-purple-700 font-mono">{{ ACTION_NAME }}</span>
        -->
        {{ ACTION_CHIPS }}
      </div>
    </header>

    <!-- Frames -->
    <!-- AGENT: emit one section per state in prototype.json.frames
      EXAMPLE PATTERN:
      <section class="space-y-4">
        <div class="border-l-4 border-brand-primary pl-4">
          <p class="text-xs uppercase tracking-wider text-gray-500">State</p>
          <h2 class="text-2xl font-semibold text-gray-900">{{ STATE_LABEL }}</h2>
          <p class="text-sm text-gray-600 mt-1">{{ STATE_DESCRIPTION }}</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
          <!-- if multi-breakpoint, side-by-side; else single -->
          <div class="frame-viewport mx-auto p-8" style="width: {{ BREAKPOINT_WIDTH }}px; max-width: 100%;">
            {{ FRAME_RENDERED_HTML }}  <!-- the resolved blocks rendered -->
          </div>
        </div>
      </section>
    -->
    {{ FRAMES_RENDERED }}

    <!-- Token usage summary -->
    <section class="bg-white rounded-xl border border-gray-200 p-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Tokens used (DS fidelity)</h2>
      <p class="text-sm text-gray-600 mb-6">Every visual value below traces to a DS token. Zero hardcoded values.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-3 font-mono text-sm">
        <!-- AGENT: emit one row per entry in prototype.json.tokens
          EXAMPLE:
          <div class="flex items-center justify-between border-b border-gray-100 pb-2">
            <span class="text-gray-700">{{ TOKEN_NAME }}</span>
            <code class="text-gray-500 text-xs">{{ TOKEN_REFERENCE_PATH }}</code>
            <span class="text-gray-900">{{ RESOLVED_VALUE }}</span>
          </div>
        -->
        {{ TOKEN_USAGE_ROWS }}
      </div>
    </section>

    <!-- Notes -->
    <!-- AGENT: only emit this section if prototype.json.notes is non-empty
      EXAMPLE:
      <section class="bg-amber-50 border border-amber-200 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-amber-900 mb-3">Notes</h2>
        <ul class="space-y-2 text-sm text-amber-800">
          <li>• {{ NOTE_TEXT }}</li>
        </ul>
      </section>
    -->
    {{ NOTES_SECTION_OR_EMPTY }}

  </main>

  <footer class="border-t border-gray-200 mt-16">
    <div class="max-w-6xl mx-auto px-8 py-6 text-center text-sm text-gray-500">
      <p>Update with <code class="bg-gray-100 px-2 py-1 rounded font-mono text-xs">/dst-edit-prototype {{ name }} "&lt;change&gt;"</code></p>
    </div>
  </footer>

</body>
</html>
