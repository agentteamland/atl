<!-- Checkbox — spec card render
     Source spec: ds-architect-agent/children/components/forms.md#checkbox -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Checkbox</h3>
    <p class="text-xs text-gray-500 font-mono">2 variants · 2 sizes · 5 states</p>
  </div>
  <p class="dst-component-intro">Binary or tri-state choice. Used in lists ("select all"), forms ("agree to terms"), filters ("include archived").</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">default</span>
      <span class="dst-spec-pill dst-pill-variant">filled</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 16px</span>
      <span class="dst-spec-pill dst-pill-size">md · 20px</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">unchecked</span>
      <span class="dst-spec-pill dst-pill-state">checked</span>
      <span class="dst-spec-pill dst-pill-state">indeterminate</span>
      <span class="dst-spec-pill dst-pill-state">focus</span>
      <span class="dst-spec-pill dst-pill-state">disabled</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Label pairing:</strong> label sits to the right, 8px gap. Click on label toggles checkbox. <strong>Indeterminate:</strong> horizontal bar (not tick) — used in "select all" headers when partially checked.</div>
</div>
