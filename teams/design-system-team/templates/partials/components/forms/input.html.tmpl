<!-- Input — mini-UI render
     Source spec: ds-architect-agent/children/components/forms.md#input
     Per-DS: pv-input-* classes defined in detail.html inline <style> block. -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Input</h3>
    <p class="text-xs text-gray-500 font-mono">2 variants · 3 sizes · 5 states</p>
  </div>
  <p class="dst-component-intro">Single-line text field. The default form primitive — paired with a label and optional helper text.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values" style="align-items:center; gap:12px; flex-direction:column; align-items:stretch;">
      <div>
        <p class="text-xs text-gray-500 mb-1 font-mono">default — on cards</p>
        <input type="text" class="pv-input" placeholder="you@example.com" />
      </div>
      <div>
        <p class="text-xs text-gray-500 mb-1 font-mono">filled — on white surface</p>
        <input type="text" class="pv-input pv-input-filled" placeholder="Search…" />
      </div>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values" style="align-items:center; gap:12px; flex-direction:column; align-items:stretch;">
      <input type="text" class="pv-input pv-input-sm" placeholder="Small · 36px" />
      <input type="text" class="pv-input" placeholder="Default · 44px" />
      <input type="text" class="pv-input pv-input-lg" placeholder="Large · 52px" />
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values" style="align-items:center; gap:12px; flex-direction:column; align-items:stretch;">
      <input type="text" class="pv-input" placeholder="Idle — empty" />
      <input type="text" class="pv-input pv-state-focus" value="Focused" />
      <input type="text" class="pv-input" value="Filled value" />
      <div>
        <input type="text" class="pv-input pv-state-error" value="invalid@" />
        <p class="text-xs mt-1" style="color:#B42318;">Please enter a valid email address.</p>
      </div>
      <input type="text" class="pv-input" value="Disabled" disabled style="opacity:0.5; cursor:not-allowed;" />
    </div>
  </div>

  <div class="dst-spec-note"><strong>Pair rule:</strong> always pair an input with a <code>&lt;label&gt;</code> — never rely on placeholder as the label substitute (placeholder disappears on focus and is invisible to screen readers).</div>
</div>
