<!-- Select — mini-UI render
     Source spec: ds-architect-agent/children/components/forms.md#select
     Per-DS: pv-select-* classes defined in detail.html inline <style> block. -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Select</h3>
    <p class="text-xs text-gray-500 font-mono">2 variants · 3 sizes · 6 states</p>
  </div>
  <p class="dst-component-intro">Triggers a menu of options. Visual treatment matches input; menu appears anchored 4px below trigger.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Closed</span>
    <div class="dst-spec-values" style="align-items:center; gap:12px; flex-direction:column; align-items:stretch;">
      <button type="button" class="pv-select" style="display:flex; align-items:center; justify-content:space-between; width:100%;">
        <span>Choose category</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Open</span>
    <div class="dst-spec-values" style="flex-direction:column; align-items:stretch; gap:0;">
      <button type="button" class="pv-select pv-state-focus" style="display:flex; align-items:center; justify-content:space-between; width:100%; border-bottom-left-radius:0; border-bottom-right-radius:0;">
        <span>Restaurants</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(180deg);"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <ul class="pv-select-menu" style="border:1px solid #E8E9E7; border-top:none; border-bottom-left-radius:12px; border-bottom-right-radius:12px; background:white; box-shadow:0 4px 8px rgba(15,23,42,0.08); padding:4px; list-style:none; margin:0;">
        <li class="pv-select-item" style="padding:8px 12px; border-radius:8px; font-size:13px;">Restaurants</li>
        <li class="pv-select-item pv-state-hover" style="padding:8px 12px; border-radius:8px; font-size:13px; background:#F5F5F4;">Cafés</li>
        <li class="pv-select-item" style="padding:8px 12px; border-radius:8px; font-size:13px;">Bars</li>
        <li class="pv-select-item" style="padding:8px 12px; border-radius:8px; font-size:13px;">Markets</li>
      </ul>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Native vs custom:</strong> custom select renders our own menu (this preview). For mobile prototypes, prototype-agent may render native pickers — that's a prototype-level decision, not a DS-level one.</div>
</div>
