<!-- Radio — spec card render
     Source spec: ds-architect-agent/children/components/forms.md#radio -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Radio</h3>
    <p class="text-xs text-gray-500 font-mono">1 variant · 2 sizes · 4 states</p>
  </div>
  <p class="dst-component-intro">Single-choice from a small fixed set. Use checkbox if more than one can be selected; use select if more than ~6 options.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">default</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 16px</span>
      <span class="dst-spec-pill dst-pill-size">md · 20px</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">unchecked</span>
      <span class="dst-spec-pill dst-pill-state">checked</span>
      <span class="dst-spec-pill dst-pill-state">focus</span>
      <span class="dst-spec-pill dst-pill-state">disabled</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Group rule:</strong> always rendered as a <code>radio.group</code> — exactly one of N must be selectable. Single radio with no group is a code smell — use checkbox.</div>
</div>
