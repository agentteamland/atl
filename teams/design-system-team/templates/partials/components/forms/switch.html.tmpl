<!-- Switch — mini-UI render
     Source spec: ds-architect-agent/children/components/forms.md#switch
     Per-DS: pv-switch-* classes defined in detail.html inline <style> block. -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Switch</h3>
    <p class="text-xs text-gray-500 font-mono">1 variant · 2 sizes · 4 states</p>
  </div>
  <p class="dst-component-intro">Binary on/off control with immediate effect. Distinct from checkbox (which captures a value to be saved later).</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values" style="align-items:center; gap:24px;">
      <label style="display:inline-flex; align-items:center; gap:12px; cursor:pointer;">
        <span class="text-sm text-gray-700">Off</span>
        <span class="pv-switch" style="display:inline-block; width:40px; height:24px; background:#D3D6D1; border-radius:9999px; position:relative; transition:background 160ms;">
          <span style="position:absolute; left:3px; top:3px; width:18px; height:18px; background:white; border-radius:9999px; box-shadow:0 1px 2px rgba(0,0,0,0.16); transition:transform 160ms;"></span>
        </span>
      </label>
      <label style="display:inline-flex; align-items:center; gap:12px; cursor:pointer;">
        <span class="text-sm text-gray-700">On</span>
        <span class="pv-switch pv-switch-on" style="display:inline-block; width:40px; height:24px; border-radius:9999px; position:relative;">
          <span style="position:absolute; right:3px; top:3px; width:18px; height:18px; background:white; border-radius:9999px; box-shadow:0 1px 2px rgba(0,0,0,0.16);"></span>
        </span>
      </label>
      <label style="display:inline-flex; align-items:center; gap:12px; cursor:pointer; opacity:0.4;">
        <span class="text-sm text-gray-700">Disabled</span>
        <span class="pv-switch" style="display:inline-block; width:40px; height:24px; background:#D3D6D1; border-radius:9999px; position:relative;">
          <span style="position:absolute; left:3px; top:3px; width:18px; height:18px; background:white; border-radius:9999px;"></span>
        </span>
      </label>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Label position:</strong> the label sits to the LEFT of the switch (opposite of checkbox/radio). Trailing position implies the value is the result of the action — "Notifications · ON".</div>
</div>
