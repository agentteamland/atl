<!-- List — spec card render
     Source spec: ds-architect-agent/children/components/display.md#list -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">List</h3>
    <p class="text-xs text-gray-500 font-mono">3 variants · 3 sizes · 4 states</p>
  </div>
  <p class="dst-component-intro">Vertical sequence of similar items. Lighter than table — used when items aren't comparable across columns.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">default · with dividers</span>
      <span class="dst-spec-pill dst-pill-variant">card · each row mini-card</span>
      <span class="dst-spec-pill dst-pill-variant">ghost · stripped</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 44px row</span>
      <span class="dst-spec-pill dst-pill-size">md · 56px row</span>
      <span class="dst-spec-pill dst-pill-size">lg · 72px row</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">idle</span>
      <span class="dst-spec-pill dst-pill-state">hover</span>
      <span class="dst-spec-pill dst-pill-state">selected</span>
      <span class="dst-spec-pill dst-pill-state">focus</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Row structure:</strong> (optional) leading visual (avatar / icon / chevron) | primary text | (optional) secondary text | (optional) trailing visual (badge / meta / icon-button).</div>
</div>
