<!-- Table — spec card render
     Source spec: ds-architect-agent/children/components/display.md#table -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Table</h3>
    <p class="text-xs text-gray-500 font-mono">3 variants · 3 sizes · 4 states</p>
  </div>
  <p class="dst-component-intro">Tabular dataset with rows and columns. Heavyweight component — only used when the data is genuinely tabular (sortable, filterable, comparable across rows).</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">default · row-only borders</span>
      <span class="dst-spec-pill dst-pill-variant">bordered · all cell borders</span>
      <span class="dst-spec-pill dst-pill-variant">striped · zebra rows</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 36px row</span>
      <span class="dst-spec-pill dst-pill-size">md · 48px row</span>
      <span class="dst-spec-pill dst-pill-size">lg · 60px row</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">idle</span>
      <span class="dst-spec-pill dst-pill-state">hover</span>
      <span class="dst-spec-pill dst-pill-state">selected</span>
      <span class="dst-spec-pill dst-pill-state">sorted</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Features:</strong> sortable columns · row selection (checkbox column + bulk-action toolbar) · sticky header · sticky first column · always pair with empty-state component when zero rows.</div>
</div>
