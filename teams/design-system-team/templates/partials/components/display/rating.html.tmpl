<!-- Rating — spec card render
     Source spec: ds-architect-agent/children/components/display.md#rating -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Rating</h3>
    <p class="text-xs text-gray-500 font-mono">3 variants · 3 sizes · 4 states</p>
  </div>
  <p class="dst-component-intro">Star (or other shape) rating display and input.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">stars · most familiar</span>
      <span class="dst-spec-pill dst-pill-variant">hearts · favorite-style</span>
      <span class="dst-spec-pill dst-pill-variant">dots · compact</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 14px icon</span>
      <span class="dst-spec-pill dst-pill-size">md · 20px icon</span>
      <span class="dst-spec-pill dst-pill-size">lg · 28px icon</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">readonly</span>
      <span class="dst-spec-pill dst-pill-state">interactive</span>
      <span class="dst-spec-pill dst-pill-state">hover</span>
      <span class="dst-spec-pill dst-pill-state">disabled</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Half-star rule:</strong> declare <code>step: 0.5</code> for fractional ratings; default is integer-only. <strong>Hover preview:</strong> filled icons up to hovered position before clicking.</div>
</div>
