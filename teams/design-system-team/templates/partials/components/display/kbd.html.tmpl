<!-- Kbd (keyboard shortcut display) — spec card render
     Source spec: ds-architect-agent/children/components/display.md#kbd -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Kbd</h3>
    <p class="text-xs text-gray-500 font-mono">2 variants · 3 sizes · 2 states</p>
  </div>
  <p class="dst-component-intro">Keyboard shortcut display — renders as elevated key cap.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">default · single key</span>
      <span class="dst-spec-pill dst-pill-variant">combo · multi-key</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 18px</span>
      <span class="dst-spec-pill dst-pill-size">md · 22px</span>
      <span class="dst-spec-pill dst-pill-size">lg · 26px</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">idle</span>
      <span class="dst-spec-pill dst-pill-state">pressed · animation only</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Platform rule:</strong> <code>platform: 'auto' | 'mac' | 'win'</code>. 'auto' reads navigator.userAgent · 'mac' shows ⌘/⌥/⇧/⌃ · 'win' shows Ctrl/Alt/Shift. <strong>Combo separator:</strong> "+" between keys.</div>
</div>
