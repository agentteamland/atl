<!-- Code (inline + block) — spec card render
     Source spec: ds-architect-agent/children/components/display.md#code -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Code</h3>
    <p class="text-xs text-gray-500 font-mono">3 variants · 2 sizes · 2 states</p>
  </div>
  <p class="dst-component-intro">Inline code or block of code with optional syntax highlighting.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">inline · &lt;code&gt;</span>
      <span class="dst-spec-pill dst-pill-variant">block · &lt;pre&gt;&lt;code&gt;</span>
      <span class="dst-spec-pill dst-pill-variant">filename · with header bar</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 12px font</span>
      <span class="dst-spec-pill dst-pill-size">md · 14px font</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">idle</span>
      <span class="dst-spec-pill dst-pill-state">copied</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Block features:</strong> optional copy button (top-right) · filename variant adds header bar (filename left + language pill + copy icon). <strong>Syntax theme:</strong> follows DS palette (keywords brand.300, strings warning, comments muted).</div>
</div>
