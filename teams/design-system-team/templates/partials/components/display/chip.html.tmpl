<!-- Chip — mini-UI render
     Source spec: ds-architect-agent/children/components/display.md#chip
     Per-DS: pv-chip-* classes defined in detail.html inline <style> block. -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Chip</h3>
    <p class="text-xs text-gray-500 font-mono">4 variants · 2 sizes · 4 states</p>
  </div>
  <p class="dst-component-intro">Interactive tag. Used for filters, selectable categories, removable inputs. Distinct from badge (badge is non-interactive — count, status).</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values" style="align-items:center; gap:8px;">
      <span class="pv-chip pv-chip-filled">Filled</span>
      <span class="pv-chip pv-chip-outlined">Outlined</span>
      <span class="pv-chip pv-chip-ghost">Ghost</span>
      <span class="pv-chip pv-chip-brand">Brand</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values" style="align-items:center; gap:8px;">
      <span class="pv-chip pv-chip-outlined pv-chip-sm">Small · 24px</span>
      <span class="pv-chip pv-chip-outlined">Default · 32px</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values" style="align-items:center; gap:8px;">
      <span class="pv-chip pv-chip-outlined">Idle</span>
      <span class="pv-chip pv-chip-outlined pv-state-hover">Hover</span>
      <span class="pv-chip pv-chip-filled">Selected</span>
      <span class="pv-chip pv-chip-outlined" style="opacity:0.4;">Disabled</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Optional adornments:</strong> leading icon (16px, 6px gap) for category hint; trailing × icon for removable chips (input chips, applied filters).</div>
</div>
