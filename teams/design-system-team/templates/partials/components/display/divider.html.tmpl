<!-- Divider — spec card render
     Source spec: ds-architect-agent/children/components/display.md#divider -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Divider</h3>
    <p class="text-xs text-gray-500 font-mono">3 variants · 3 sizes · 1 state</p>
  </div>
  <p class="dst-component-intro">Visible separation between regions.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">default · 1px</span>
      <span class="dst-spec-pill dst-pill-variant">muted · 0.5 opacity</span>
      <span class="dst-spec-pill dst-pill-variant">labeled · center text</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">tight · 8px marginY</span>
      <span class="dst-spec-pill dst-pill-size">default · 16px marginY</span>
      <span class="dst-spec-pill dst-pill-size">loose · 32px marginY</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">idle</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Orientation:</strong> horizontal (default) or vertical (declare <code>orientation: 'vertical'</code>). <strong>Labeled variant:</strong> center text label with small horizontal padding, surface-colored background to "cut" the line.</div>
</div>
