<!-- Stepper — spec card render
     Source spec: ds-architect-agent/children/components/navigation.md#stepper -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Stepper</h3>
    <p class="text-xs text-gray-500 font-mono">2 variants · 2 sizes · 4 states</p>
  </div>
  <p class="dst-component-intro">Sequential progress through a multi-step flow. Shows where the user is, where they came from, where they're going.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">horizontal · desktop</span>
      <span class="dst-spec-pill dst-pill-variant">vertical · mobile / dense</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 24px circle</span>
      <span class="dst-spec-pill dst-pill-size">md · 32px circle</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">pending</span>
      <span class="dst-spec-pill dst-pill-state">current</span>
      <span class="dst-spec-pill dst-pill-state">completed</span>
      <span class="dst-spec-pill dst-pill-state">error</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Connector rule:</strong> connectors between steps reflect the state BEFORE the next circle. Connector from step 2 to step 3 is filled if step 2 is completed.</div>
</div>
