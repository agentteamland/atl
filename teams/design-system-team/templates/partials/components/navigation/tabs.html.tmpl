<!-- Tabs — spec card render
     Source spec: ds-architect-agent/children/components/navigation.md#tabs -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Tabs</h3>
    <p class="text-xs text-gray-500 font-mono">3 variants · 2 sizes · 5 states</p>
  </div>
  <p class="dst-component-intro">Sibling sections of the same parent. The tab strip is the navigation; the content below is what changes.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">underline · default</span>
      <span class="dst-spec-pill dst-pill-variant">pill · compact</span>
      <span class="dst-spec-pill dst-pill-variant">segmented · iOS-style</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 32px</span>
      <span class="dst-spec-pill dst-pill-size">md · 40px</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">idle</span>
      <span class="dst-spec-pill dst-pill-state">hover</span>
      <span class="dst-spec-pill dst-pill-state">active</span>
      <span class="dst-spec-pill dst-pill-state">disabled</span>
      <span class="dst-spec-pill dst-pill-state">focus</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Overflow:</strong> horizontal scroll on mobile (no wrap); on desktop, overflow tabs collapse into a "More ▼" menu. <strong>Keyboard:</strong> ←/→ navigate, Enter activates.</div>
</div>
