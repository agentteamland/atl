<!-- Breadcrumb — spec card render
     Source spec: ds-architect-agent/children/components/navigation.md#breadcrumb -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Breadcrumb</h3>
    <p class="text-xs text-gray-500 font-mono">2 variants · 2 sizes · 3 states</p>
  </div>
  <p class="dst-component-intro">Path back to ancestor pages. Used when hierarchy is more than 2 levels deep — for shallow trees, a back button suffices.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">default · ›</span>
      <span class="dst-spec-pill dst-pill-variant">slash · /</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · caption</span>
      <span class="dst-spec-pill dst-pill-size">md · bodySmall</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">idle</span>
      <span class="dst-spec-pill dst-pill-state">hover</span>
      <span class="dst-spec-pill dst-pill-state">focus</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Overflow:</strong> if 4+ levels, collapse middle to "…" that expands on click. Always show first and last. <strong>Current item</strong> never underlines on hover — it's not navigable.</div>
</div>
