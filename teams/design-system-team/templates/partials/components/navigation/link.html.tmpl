<!-- Link — spec card render
     Source spec: ds-architect-agent/children/components/navigation.md#link -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Link</h3>
    <p class="text-xs text-gray-500 font-mono">4 variants · 3 sizes · 5 states</p>
  </div>
  <p class="dst-component-intro">Generic link primitive. Distinct from button (button triggers an action; link navigates).</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">default · underline-on-hover</span>
      <span class="dst-spec-pill dst-pill-variant">inline · always-underlined</span>
      <span class="dst-spec-pill dst-pill-variant">nav · no-underline</span>
      <span class="dst-spec-pill dst-pill-variant">external · with ↗ icon</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · caption</span>
      <span class="dst-spec-pill dst-pill-size">md · body</span>
      <span class="dst-spec-pill dst-pill-size">lg · bodyLarge</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">idle</span>
      <span class="dst-spec-pill dst-pill-state">hover</span>
      <span class="dst-spec-pill dst-pill-state">focus</span>
      <span class="dst-spec-pill dst-pill-state">active</span>
      <span class="dst-spec-pill dst-pill-state">visited</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Semantics rule:</strong> always uses semantic <code>&lt;a&gt;</code> element with href. Never <code>&lt;button&gt;</code> styled as link or <code>&lt;span onClick&gt;</code>. <strong>External:</strong> adds 12px ↗ icon and <code>target="_blank" rel="noopener"</code>.</div>
</div>
