<!-- Bottom-navigation — spec card render
     Source spec: ds-architect-agent/children/components/navigation.md#bottom-navigation -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Bottom-navigation</h3>
    <p class="text-xs text-gray-500 font-mono">3 variants · 1 size · 4 states</p>
  </div>
  <p class="dst-component-intro">Mobile bottom nav bar. Always pinned to viewport bottom; safe-area-inset for iOS notch devices.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">icon-only · 3-5 items</span>
      <span class="dst-spec-pill dst-pill-variant">labeled · icon + label</span>
      <span class="dst-spec-pill dst-pill-variant">floating · with FAB</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">default · 64px height</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">idle</span>
      <span class="dst-spec-pill dst-pill-state">active</span>
      <span class="dst-spec-pill dst-pill-state">focus</span>
      <span class="dst-spec-pill dst-pill-state">disabled</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Constraint:</strong> always 3-5 items max — overflow goes to a "More" drawer. <strong>Active:</strong> brand.primary fill on icon + label · optional 4px brand.primary indicator above icon. <strong>Floating:</strong> FAB sits 16px above bar's top edge.</div>
</div>
