<!-- Toast — spec card render
     Source spec: ds-architect-agent/children/components/feedback.md#toast -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Toast</h3>
    <p class="text-xs text-gray-500 font-mono">4 variants · 1 size · 3 states</p>
  </div>
  <p class="dst-component-intro">Transient notification that auto-dismisses. Stacks at a corner of the viewport.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">info</span>
      <span class="dst-spec-pill dst-pill-variant">success</span>
      <span class="dst-spec-pill dst-pill-variant">warning</span>
      <span class="dst-spec-pill dst-pill-variant">error</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">md · 280-420px</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">entering</span>
      <span class="dst-spec-pill dst-pill-state">visible</span>
      <span class="dst-spec-pill dst-pill-state">exiting</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Behavior:</strong> auto-dismiss 5000ms (success/info), 8000ms (warning/error); hover pauses timer · max 3 stacked, older auto-dismiss · bottom-right desktop / top-center mobile.</div>
</div>
