<!-- Tooltip — spec card render
     Source spec: ds-architect-agent/children/components/feedback.md#tooltip -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Tooltip</h3>
    <p class="text-xs text-gray-500 font-mono">1 variant · 2 sizes · 2 states</p>
  </div>
  <p class="dst-component-intro">Tiny label revealed on hover or focus. For terse hints — "Save (⌘S)", "Last updated 3m ago", icon-button labels.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">default</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 4px padding</span>
      <span class="dst-spec-pill dst-pill-size">md · 6px padding</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">hidden</span>
      <span class="dst-spec-pill dst-pill-state">visible</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Behavior:</strong> hover (300ms delay) or focus (immediate) · max 240px width · 8px arrow on side facing trigger · flips above/below if clipped at viewport edge.</div>
</div>
