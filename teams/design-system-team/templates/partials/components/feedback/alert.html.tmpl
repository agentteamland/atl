<!-- Alert — spec card render
     Source spec: ds-architect-agent/children/components/feedback.md#alert -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Alert</h3>
    <p class="text-xs text-gray-500 font-mono">4 variants · 2 sizes · 2 states</p>
  </div>
  <p class="dst-component-intro">Inline, dismissible message attached to a region. Used at the top of forms, inside cards, above lists.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">info</span>
      <span class="dst-spec-pill dst-pill-variant">success</span>
      <span class="dst-spec-pill dst-pill-variant">warning</span>
      <span class="dst-spec-pill dst-pill-variant">error</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 10px padding</span>
      <span class="dst-spec-pill dst-pill-size">md · 14px padding</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">idle</span>
      <span class="dst-spec-pill dst-pill-state">dismissed</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Structure:</strong> icon | title + body | (optional) action button | (optional) close icon-button. <strong>Dismissed:</strong> animates out (accelerate, fast); persisted dismissal optional.</div>
</div>
