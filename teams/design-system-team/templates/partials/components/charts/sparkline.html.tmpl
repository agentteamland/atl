<!-- Sparkline — spec card render
     Source spec: ds-architect-agent/children/components/charts.md#sparkline -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Sparkline</h3>
    <p class="text-xs text-gray-500 font-mono">3 variants · 3 sizes · 2 states</p>
  </div>
  <p class="dst-component-intro">Inline mini-chart. No axes, no labels — pure shape that fits inside a stat card or table cell.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">line · trend hint</span>
      <span class="dst-spec-pill dst-pill-variant">bar · discrete comparison</span>
      <span class="dst-spec-pill dst-pill-variant">area · trend with magnitude</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 24px tall</span>
      <span class="dst-spec-pill dst-pill-size">md · 32px tall</span>
      <span class="dst-spec-pill dst-pill-size">lg · 48px tall</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">idle</span>
      <span class="dst-spec-pill dst-pill-state">hover · cursor dot</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Composition rule:</strong> width fills container · no padding, no margins — the shape is the entire visual. <strong>Use:</strong> renders inline within stat / table cells / list rows. Color from <code>brand.primary</code> by default.</div>
</div>
