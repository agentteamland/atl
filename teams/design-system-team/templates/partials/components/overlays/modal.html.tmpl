        <div class="pv-modal" style="background:white; border-radius:16px; padding:24px; width:100%; max-width:360px; box-shadow:0 24px 48px rgba(15,23,42,0.32);">
          <h4 class="text-base font-semibold text-gray-900 mb-2">Delete this list?</h4>
