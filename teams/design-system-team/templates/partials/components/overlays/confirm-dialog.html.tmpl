      <span class="dst-spec-pill dst-pill-variant">critical · typed confirmation</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 360px</span>
      <span class="dst-spec-pill dst-pill-size">md · 480px</span>
    </div>
