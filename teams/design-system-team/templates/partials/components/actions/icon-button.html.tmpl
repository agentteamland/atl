<!-- Icon-button — spec card render
     Source spec: ds-architect-agent/children/components/actions.md#icon-button -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Icon-button</h3>
    <p class="text-xs text-gray-500 font-mono">4 variants · 3 sizes · 5 states</p>
  </div>
  <p class="dst-component-intro">Square button whose only content is an icon. Different shape from button — keeps icon-only affordances from being mistaken for plain icons.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-variant">default</span>
      <span class="dst-spec-pill dst-pill-variant">filled</span>
      <span class="dst-spec-pill dst-pill-variant">primary</span>
      <span class="dst-spec-pill dst-pill-variant">danger</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-size">sm · 32px</span>
      <span class="dst-spec-pill dst-pill-size">md · 40px</span>
      <span class="dst-spec-pill dst-pill-size">lg · 48px</span>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values">
      <span class="dst-spec-pill dst-pill-state">idle</span>
      <span class="dst-spec-pill dst-pill-state">hover</span>
      <span class="dst-spec-pill dst-pill-state">focus</span>
      <span class="dst-spec-pill dst-pill-state">pressed</span>
      <span class="dst-spec-pill dst-pill-state">disabled</span>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Accessibility:</strong> icon-buttons MUST have an accessible name (<code>aria-label</code>). The icon itself is decorative — screen readers announce the label, not the icon.</div>
</div>
