<!-- Button — mini-UI render
     Source spec: ds-architect-agent/children/components/actions.md#button
     Per-DS: pv-btn-* / pv-state-* classes defined in detail.html inline <style> block. -->
<div class="dst-component-card">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-medium text-gray-900">Button</h3>
    <p class="text-xs text-gray-500 font-mono">4 variants · 3 sizes · 6 states</p>
  </div>
  <p class="dst-component-intro">Main interactive element. Four variants cover the entire CTA spectrum from primary to destructive.</p>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Variants</span>
    <div class="dst-spec-values" style="align-items:center; gap:12px;">
      <button class="pv-btn pv-btn-primary">Primary</button>
      <button class="pv-btn pv-btn-secondary">Secondary</button>
      <button class="pv-btn pv-btn-ghost">Ghost</button>
      <button class="pv-btn pv-btn-danger">Danger</button>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">Sizes</span>
    <div class="dst-spec-values" style="align-items:center; gap:12px;">
      <button class="pv-btn pv-btn-primary pv-btn-sm">Small · 36px</button>
      <button class="pv-btn pv-btn-primary">Default · 44px</button>
      <button class="pv-btn pv-btn-primary pv-btn-lg">Large · 52px</button>
    </div>
  </div>

  <div class="dst-spec-row">
    <span class="dst-spec-label">States</span>
    <div class="dst-spec-values" style="align-items:center; gap:12px;">
      <button class="pv-btn pv-btn-primary">Idle</button>
      <button class="pv-btn pv-btn-primary pv-state-hover">Hover</button>
      <button class="pv-btn pv-btn-primary pv-state-focus">Focus</button>
      <button class="pv-btn pv-btn-primary pv-state-pressed">Pressed</button>
      <button class="pv-btn pv-btn-primary" disabled style="opacity:0.4; cursor:not-allowed;">Disabled</button>
      <button class="pv-btn pv-btn-primary" style="display:inline-flex; align-items:center; gap:8px;"><span class="dst-spinner" style="width:14px; height:14px; border-width:1.5px;"></span>Loading</button>
    </div>
  </div>

  <div class="dst-spec-note"><strong>Variant rule:</strong> if you find yourself writing a fifth variant, ask whether the new one is really <code>secondary</code> with a different color — usually it is. The four names map to four intents, not four colors.</div>
</div>
